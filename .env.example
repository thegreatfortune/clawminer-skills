# Polygon RPC URL (e.g., Alchemy, Infura, or public node)
POLYGON_RPC_URL=https://polygon-rpc.com

# Burner Wallet Private Key (Without 0x prefix, this wallet should hold some MATIC for gas and the 0.01 fee)
BURNER_WALLET_PRIVATE_KEY=your_private_key_here

# The ClawMiner Protocol Smart Contract Address on Polygon
CLAWMINER_PROTOCOL_ADDRESS=0x0000000000000000000000000000000000000000
