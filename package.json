{
  "name": "@clawminer/clawminer-skills",
  "version": "1.0.0",
  "description": "ClawMiner Skills Runtime CLI — local scripts + dist tools",
  "main": "dist/cli.js",
  "type": "module",
  "bin": {
    "clawminer": "dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && mkdir -p dist/contracts dist/skills && cp -R src/contracts/* dist/contracts/ && cp -R src/skills/* dist/skills/",
    "dev": "tsx src/cli.ts",
    "list": "node dist/cli.js list",
    "test": "echo \"No tests configured\" && exit 0"
  },
  "keywords": [
    "openclaw-plugin",
    "clawminer",
    "polymarket",
    "polygon"
  ],
  "author": "ClawMiner Team",
  "license": "MIT",
  "dependencies": {
    "axios": "1.13.6",
    "better-sqlite3": "12.6.2",
    "circomlibjs": "0.1.7",
    "dotenv": "17.3.1",
    "viem": "^2.0.0",
    "snarkjs": "0.7.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.5.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "blake-hash", "esbuild"]
  }
}
